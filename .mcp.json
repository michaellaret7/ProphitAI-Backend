{
  "mcpServers": {
    "langfuse": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--python",
        "3.11",
        "langfuse-mcp",
        "--public-key",
        "${LANGFUSE_PUBLIC_KEY}",
        "--secret-key",
        "${LANGFUSE_SECRET_KEY}",
        "--host",
        "${LANGFUSE_BASE_URL}"
      ]
    }
  }
}
