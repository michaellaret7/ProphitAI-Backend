# ============================================================================
# PROPHITAI ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual values

# ----------------------------------------------------------------------------
# LLM ROUTING (OpenRouter — single endpoint for every model the platform uses)
# ----------------------------------------------------------------------------
# All LLM calls flow through OpenRouter via the OpenAI SDK. Pick model slugs
# from https://openrouter.ai/models (e.g. anthropic/claude-sonnet-4.6,
# openai/gpt-5.4). cache_control is forwarded to upstream providers that
# support prompt caching; the rest silently drop it.

OPENROUTER_API_KEY="sk-or-v1-your-openrouter-api-key"
OPENROUTER_API_URL="https://openrouter.ai/api/v1"

# Embeddings (still direct — OpenRouter is chat-completions only)
VOYAGE_API_KEY="your-voyage-api-key"

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------

DB_HOST="your-postgres-host.example.com"
DB_USER="postgres"
DB_PASSWORD="your-database-password"
DB_PORT="5432"

DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/{DB_NAME}"
MARKET_DATA="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/market_data"
USER_DATA="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/user_data"
PROPHIT_ALTS="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/prophit_alts"
MACRO_DATA="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/macro_data"

# ----------------------------------------------------------------------------
# REDIS CONFIGURATION
# ----------------------------------------------------------------------------

REDIS_URL="redis://localhost:6379"
REDIS_EXTERNAL_URL="rediss://your-redis-external-url:6379"
REDIS_INTERNAL_URL="redis://your-redis-internal-url:6379"

# ----------------------------------------------------------------------------
# AUTHENTICATION & SECURITY
# ----------------------------------------------------------------------------

# Clerk
CLERK_SECRET_KEY="sk_test_your-clerk-secret-key"
CLERK_JWKS_URL="https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json"
CLERK_WEBHOOK_SECRET="whsec_your-clerk-webhook-secret"

# Internal API Keys (comma-separated)
PROPHITAI_API_KEYS="key1,key2,key3"

# Encryption (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
MESSAGE_ENCRYPTION_KEY="your-base64-encoded-encryption-key"

# Test User
USER_NAME="ADMIN_TEST"
USER_ID="your-test-user-id"

# ----------------------------------------------------------------------------
# FINANCIAL DATA & TRADING
# ----------------------------------------------------------------------------

# Financial Modeling Prep (https://site.financialmodelingprep.com/)
FMP_API_KEY="your-fmp-api-key"

# Alpaca Trading (https://alpaca.markets/)
ALPACA_API_KEY="your-alpaca-api-key"
ALPACA_SECRET_KEY="your-alpaca-secret-key"

# Alpaca Agent Environment 2
ALPACA_AGENT_ENV_TWO_API_KEY="your-alpaca-env2-api-key"
ALPACA_AGENT_ENV_TWO_SECRET_KEY="your-alpaca-env2-secret-key"

# Alpaca Broker
ALPACA_BROKER_API_KEY="your-alpaca-broker-api-key"
ALPACA_BROKER_SECRET_KEY="your-alpaca-broker-secret-key"
ALPACA_FIRM_ACCOUNT_ID="your-firm-account-id"
ALPACA_BROKER_FUNDING_ACCOUNT_ID="your-funding-account-id"

# SnapTrade (https://snaptrade.com/)
SNAPTRADE_CLIENT_ID="your-snaptrade-client-id"
SNAPTRADE_CONSUMER_KEY="your-snaptrade-consumer-key"

# ----------------------------------------------------------------------------
# SEARCH & RESEARCH TOOLS
# ----------------------------------------------------------------------------

EXA_API_KEY="your-exa-api-key"
TAVILY_API_KEY="tvly-your-tavily-api-key"

# ----------------------------------------------------------------------------
# AWS
# ----------------------------------------------------------------------------

AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_DEFAULT_REGION="us-east-1"
S3_BUCKET="your-s3-bucket-name"

# ----------------------------------------------------------------------------
# VECTOR DATABASE (Pinecone)
# ----------------------------------------------------------------------------

PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_INDEX_NAME="prophitai-rag"
PINECONE_HOST="https://your-pinecone-index.svc.pinecone.io"
TOKENIZERS_PARALLELISM=false

# ----------------------------------------------------------------------------
# OBSERVABILITY & MONITORING
# ----------------------------------------------------------------------------

# Langfuse (https://langfuse.com/)
LANGFUSE_SECRET_KEY="sk-lf-your-langfuse-secret-key"
LANGFUSE_PUBLIC_KEY="pk-lf-your-langfuse-public-key"
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"

# Braintrust
BRAINTRUST_API_KEY="your-braintrust-api-key"

# ----------------------------------------------------------------------------
# INFRASTRUCTURE
# ----------------------------------------------------------------------------

# Modal (Serverless GPU - https://modal.com/)
# run `modal token create` to create the token id and secret
# run cat ~/.modal.toml to get the token id and secret
MODAL_API_KEY="your-modal-api-key"
MODAL_TOKEN_ID="your-modal-token-id"
MODAL_TOKEN_SECRET="your-modal-token-secret"

# Ngrok (Tunneling)
NGROK_TOKEN="your-ngrok-token"

# ----------------------------------------------------------------------------
# APPLICATION SETTINGS
# ----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"

RENDER_API_KEY="render-your-render-api-key"
RENDER_OWNER_ID="your-render-owner-id"
RENDER_FUND_PROJECT_ID="your-render-fund-project-id"
RENDER_FUND_ENVIRONMENT_ID="your-render-fund-environment-id"
