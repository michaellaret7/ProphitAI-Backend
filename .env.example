# ============================================================================
# PROPHITAI ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual values

# ----------------------------------------------------------------------------
# LLM PROVIDER API KEYS
# ----------------------------------------------------------------------------

# Primary LLM Providers
OPENAI_API_KEY="sk-proj-your-openai-api-key"
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"
GROK_API_KEY="xai-your-grok-api-key"
GEMINI_API_KEY="your-gemini-api-key"
DEEPSEEK_API_KEY="sk-your-deepseek-api-key"
PERPLEXITY_API_KEY="pplx-your-perplexity-api-key"

# Inference Providers (Fast/Cheap alternatives)
TOGETHER_AI_API_KEY="your-together-ai-api-key"
GROQ_API_KEY="gsk-your-groq-api-key"
FIREWORKS_API_KEY="fw-your-fireworks-api-key"

# Hugging Face
HF_TOKEN="hf_your-huggingface-token"

# ----------------------------------------------------------------------------
# LLM MODEL CONFIGURATION
# ----------------------------------------------------------------------------

OPENAI_MODEL="gpt-4o"
ANTHROPIC_MODEL="claude-sonnet-4-5-20250929"
GROK_MODEL="grok-4-fast-reasoning"
GEMINI_MODEL="gemini-3-pro-preview"
DEEPSEEK_MODEL="deepseek-chat"
PERPLEXITY_MODEL="sonar-pro"

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------

# PostgreSQL Connection
DB_HOST="your-postgres-host.example.com"
DB_USER="postgres"
DB_PASSWORD="your-database-password"
DB_PORT="5432"

# Database URLs
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/{DB_NAME}"
MARKET_DATA="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/market_data"
USER_DATA="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/user_data"
PROPHIT_ALTS="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/prophit_alts"
MACRO_DATA="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/macro_data"

# ----------------------------------------------------------------------------
# REDIS CONFIGURATION
# ----------------------------------------------------------------------------

# Local: redis://localhost:6379
# Cloud: rediss://default:password@your-redis-host:6379
REDIS_URL="redis://localhost:6379"
REDIS_EXTERNAL_URL="rediss://your-redis-external-url:6379"
REDIS_INTERNAL_URL="redis://your-redis-internal-url:6379"

# ----------------------------------------------------------------------------
# AUTHENTICATION & SECURITY
# ----------------------------------------------------------------------------

# Clerk Authentication
CLERK_SECRET_KEY="sk_test_your-clerk-secret-key"
CLERK_JWKS_URL="https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json"
CLERK_WEBHOOK_SECRET="whsec_your-clerk-webhook-secret"

# Internal API Keys (comma-separated list of valid keys)
PROPHITAI_API_KEYS="key1,key2,key3"

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
MESSAGE_ENCRYPTION_KEY="your-base64-encoded-encryption-key"

# ----------------------------------------------------------------------------
# EXTERNAL SERVICE API KEYS
# ----------------------------------------------------------------------------

# Financial Data (https://site.financialmodelingprep.com/)
FMP_API_KEY="your-financial-modeling-prep-api-key"

# Alpaca Trading (https://alpaca.markets/)
ALPACA_API_KEY="your-alpaca-api-key"
ALPACA_SECRET_KEY="your-alpaca-secret-key"

# Search (https://exa.ai/)
EXA_API_KEY="your-exa-api-key"

# Notion (MCP Integration)
NOTION_TOKEN="ntn_your-notion-integration-token"

# ----------------------------------------------------------------------------
# APPLICATION SETTINGS
# ----------------------------------------------------------------------------

# Logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"
