# LLM KEYS
OPENAI_API_KEY=your_openai_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROK_API_KEY=your_grok_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here

# MODELS
OPENAI_MODEL="gpt-4.1"
PERPLEXITY_MODEL="sonar-pro"
ANTHROPIC_MODEL="claude-3-7-sonnet-20250219"
DEEPSEEK_MODEL="deepseek-chat"
GROK_MODEL="grok-3-beta"

# DATABASE INFO
DB_HOST="your_database_host_here"
DB_USER="your_database_user_here"
DB_PASSWORD=your_database_password_here
DB_PORT="5432"
MARKET_DATA="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/market_data"
USER_DATA="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/user_data"

# REDIS CACHE
# Redis connection URL for caching (supports redis:// or rediss:// for TLS)
# Local: redis://localhost:6379
# Cloud: rediss://default:password@your-redis-host:6379
REDIS_URL=redis://localhost:6379

# LOG OUTPUT LEVEL --> DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"

# Financial modelling prep api key
FMP_API_KEY=your_fmp_api_key_here

# WorkOS Credentials
WORKOS_CLIENT_ID=your_workos_client_id_here
WORKOS_API_KEY=your_workos_api_key_here
WORKOS_REDIRECT_URI="http://localhost:8000/auth/callback"
WORKOS_COOKIE_PASSWORD=your_cookie_password_min_32_chars_here

